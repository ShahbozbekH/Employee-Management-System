{
  "info": {
    "_postman_id": "employee-management-collection",
    "name": "Employee Management System API Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Add Employees",
      "item": [
        {
          "name": "Add Jane Doe",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employee_id\": \"E002\",\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"department\": \"Operations\",\n  \"position\": \"Project Manager\",\n  \"status\": \"Active\"\n}"
            },
            "url": {
              "raw": "http://localhost:8000/employees/employee",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["employees", "employee"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test(\"Employee added successfully\", function () {",
                  "    pm.expect(pm.response.json().message).to.eql(\"Employee added successfully\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
